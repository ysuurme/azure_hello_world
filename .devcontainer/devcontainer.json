{
  "name": "Azure Architecture Agent",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/common-utils:2.5.7": {}
  },
  "customizations": {
    "vscode": {
      "settings": {
        "python.defaultInterpreterPath": ".venv/bin/python"
      },
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-azurefunctions",
        "hashicorp.terraform",
        "charliermarsh.ruff"
      ]
    }
  },
  "remoteUser": "vscode",
  "forwardPorts": [7071, 8501]
}
