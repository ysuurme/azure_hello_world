# Copy to .env and fill in your values — never commit .env
PORT=8000
LOG_PROFILE=PRD
LOG_SEPARATOR_WIDTH=80
LOG_LINE_WIDTH=120
LOG_DIR=logs

# Path to the my_second_brain repository on disk.
# When set, CapabilityRepository reads from $SECOND_BRAIN_PATH/capabilities/
# and approved designs are written to $SECOND_BRAIN_PATH/architecture/designs/approved/.
# Leave unset to fall back to local project directories (e.g. in CI).
SECOND_BRAIN_PATH=/path/to/my_second_brain

# Orchestrator — required by task setup and the kanban workflow
KANBAN_PROJECT_NUMBER=
KANBAN_PROJECT_OWNER=

# --- Azure AI Foundry ---
# Endpoint for the AI Foundry project (Azure ML workspace endpoint).
# Obtain with: az ml workspace show --name <project> --resource-group <rg> --query discovery_url -o tsv
AZURE_AAIF_PROJECT_ENDPOINT=

# --- Azure Authentication ---
# AZURE_AUTH_MODE controls which credential flow is used.
#   cli            — DefaultAzureCredential prefers `az login` (default for local dev)
#   sp             — Force Service Principal via the three vars below
#
# Run `cd infra/project && terraform apply` to provision sp-helloarch-dev,
# then copy the outputs into the vars below.
AZURE_AUTH_MODE=cli
AZURE_CLIENT_ID=
AZURE_TENANT_ID=
AZURE_CLIENT_SECRET=

# --- Backend ---
# URL the Streamlit frontend uses to reach the FastAPI backend container.
# e.g. http://localhost:8000 for local dev or the Azure Container Apps ingress URL.
BACKEND_URL=http://localhost:8000
